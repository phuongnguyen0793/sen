{
  "expo": {
    "name": "Sen",
    "slug": "sen",
    "scheme": "sen",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "app.sen.lunar"
    },
    "android": {
      "package": "app.sen.lunar"
    },
    "extra": {
      "apiUrl": "http://localhost:8080/api/v1"
    },
    "plugins": [
      "expo-font",
      "@react-native-community/datetimepicker",
      "expo-secure-store"
    ]
  }
}
